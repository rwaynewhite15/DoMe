# ---- DoMe environment variables ----
# Copy to .env for local development and fill in.
# On Render these are set on the web service (see render.yaml).

# Neon Postgres — POOLED connection string (used by the running app).
# Get it from the Neon dashboard. Must include ?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/dome?sslmode=require"

# Neon Postgres — DIRECT (non-pooled) connection string (used for migrations).
# Same DB, the host WITHOUT "-pooler".
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/dome?sslmode=require"

# Secret used to sign session JWTs. Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"

# Email via Gmail SMTP. Leave blank to disable email (the app logs instead of sending).
# GMAIL_USER: your full Gmail address.
# GMAIL_APP_PASSWORD: a Google "App Password" (Google account → Security → 2-Step
#   Verification must be ON → App passwords). 16 chars; spaces are fine.
GMAIL_USER=""
GMAIL_APP_PASSWORD=""

# Optional override for the From line. Defaults to "DoMe <GMAIL_USER>".
# EMAIL_FROM="DoMe <you@gmail.com>"

# Shared secret to authorize the cron endpoint (/api/cron/daily). Generate a random string.
CRON_SECRET="change-me-cron-secret"

# Public base URL of the deployed app (used in email links). Set to your Render URL in prod.
APP_URL="http://localhost:3000"
